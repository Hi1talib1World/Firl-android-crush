<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg1main">

    <HorizontalScrollView
        android:id="@+id/filter_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/filter_sex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_corner_layout"
                android:backgroundTint="#33FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Sex: All"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"
                app:drawableStartCompat="@drawable/ic_user"
                android:drawablePadding="8dp"
                app:drawableTint="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/filter_age"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_corner_layout"
                android:backgroundTint="#33FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Age: 18-35"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"
                app:drawableStartCompat="@drawable/ic_launcher_background"
                android:drawablePadding="8dp"
                app:drawableTint="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/filter_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_corner_layout"
                android:backgroundTint="#33FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Distance: 50km"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_location"
                android:drawablePadding="8dp"
                app:drawableTint="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/card_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/controls_layout"
        android:layout_below="@+id/filter_bar"
        android:layout_marginTop="0dp">

        <com.lorentzos.flingswipe.SwipeFlingAdapterView
            android:id="@+id/frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:rotation_degrees="15.5" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/dislikebtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_dislike"
            app:tint="@color/dislikered" />

        <ImageButton
            android:id="@+id/commentbtn"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_comment"
            app:tint="@color/link_blue" />

        <ImageButton
            android:id="@+id/likebtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_like1"
            app:tint="@color/likegreen" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/more_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <com.Denzo.firl.Utils.PulsatorLayout
            android:id="@+id/pulsator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:pulse_color="@color/colorAccent"
            app:pulse_count="4"
            app:pulse_duration="4000"
            app:pulse_repeat="0">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/post"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_centerInParent="true"
                android:src="@drawable/monkey"
                app:civ_border_color="@color/white"
                app:civ_border_width="2dp" />

        </com.Denzo.firl.Utils.PulsatorLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="120dp"
            android:text="Finding people near you..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:alpha="0.7"/>

    </FrameLayout>

</RelativeLayout>
