<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg1main">

    <FrameLayout
        android:id="@+id/card_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/controls_layout"
        android:layout_marginTop="10dp">

        <com.lorentzos.flingswipe.SwipeFlingAdapterView
            android:id="@+id/frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:rotation_degrees="15.5" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/dislikebtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_dislike"
            app:tint="@color/dislikered" />

        <ImageButton
            android:id="@+id/commentbtn"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_comment"
            app:tint="@color/link_blue" />

        <ImageButton
            android:id="@+id/likebtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/ripple_white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_like1"
            app:tint="@color/likegreen" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/more_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <com.Denzo.firl.Utils.PulsatorLayout
            android:id="@+id/pulsator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:pulse_color="@color/colorAccent"
            app:pulse_count="4"
            app:pulse_duration="4000"
            app:pulse_repeat="0">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/post"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_centerInParent="true"
                android:src="@drawable/monkey"
                app:civ_border_color="@color/white"
                app:civ_border_width="2dp" />

        </com.Denzo.firl.Utils.PulsatorLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="120dp"
            android:text="Finding people near you..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:alpha="0.7"/>

    </FrameLayout>

</RelativeLayout>
