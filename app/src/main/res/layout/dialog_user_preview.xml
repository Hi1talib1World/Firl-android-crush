<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg_dark"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:cardCornerRadius="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/preview_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/monkey" />

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bottom_gradient" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/preview_name_age"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Victoria, 19"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/preview_bio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Just here to meet some cool people."
            android:textColor="@color/white"
            android:alpha="0.7"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/preview_action_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Send a Like"
            android:textColor="@color/bg1main"
            android:backgroundTint="@color/colorAccent"
            app:cornerRadius="12dp"
            app:icon="@drawable/love"
            app:iconGravity="textStart"
            app:iconTint="@color/bg1main" />

    </LinearLayout>

</LinearLayout>
